# ═══════════════════════════════════════════════════════════
#  FileZaar Backend — Environment Variables
#  Copy to .env and fill in values
# ═══════════════════════════════════════════════════════════

# Server
PORT=8000
HOST=0.0.0.0

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=https://filezaar.pages.dev,https://filezaar.app,http://localhost:5173

# Redis (for rate limiting and job state at scale)
REDIS_URL=redis://localhost:6379/0

# File limits
MAX_UPLOAD_MB=2048
MAX_CONCURRENT_JOBS=4
OUTPUT_TTL_SECONDS=3600

# Sentry error tracking (optional but recommended for production)
SENTRY_DSN=

# Google AdSense (optional)
ADSENSE_CLIENT=ca-pub-XXXXXXXXXXXXXXXX
